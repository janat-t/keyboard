{
  "title": "Karabinier Profile Change Shortcuts",
  "rules": [
    {
      "description": "[MOD] Mode Change Mod <-> Colemak",
      "manipulators": [
        {
          "from": {
            "key_code": "j",
            "modifiers": { "mandatory": ["left_command", "right_command"]  }
          },
          "to": [{ "shell_command": "'/Library/Application Support/org.pqrs/Karabiner-Elements/bin/karabiner_cli' --select-profile 'Mod'"  }],
          "type": "basic"
        },
        {
          "from": {
            "key_code": "k",
            "modifiers": { "mandatory": ["left_command", "right_command"]  }
          },
          "to": [{ "shell_command": "'/Library/Application Support/org.pqrs/Karabiner-Elements/bin/karabiner_cli' --select-profile 'Colemak'"  }],
          "type": "basic"
        }
      ]
    },
    {
      "description": "[COLEMAK] Profile Change Mod <-> Colemak",
      "manipulators": [
        {
          "from": {
            "key_code": "n",
            "modifiers": { "mandatory": ["left_command", "right_command"]  }
          },
          "to": [{ "shell_command": "'/Library/Application Support/org.pqrs/Karabiner-Elements/bin/karabiner_cli' --select-profile 'Mod'"  }],
          "type": "basic"
        },
        {
          "from": {
            "key_code": "e",
            "modifiers": { "mandatory": ["left_command", "right_command"]  }
          },
          "to": [{ "shell_command": "'/Library/Application Support/org.pqrs/Karabiner-Elements/bin/karabiner_cli' --select-profile 'Colemak'"  }],
          "type": "basic"
        }
      ]
    }
  ]
}
